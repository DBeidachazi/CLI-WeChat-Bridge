{
  "name": "@unlinearity/cli-wechat-bridge",
  "version": "0.9.0",
  "description": "CLI WeChat Bridge for Codex, Claude Code, OpenCode, Gemini, Copilot, and PowerShell over WeChat",
  "type": "module",
  "private": true,
  "keywords": [
    "wechat",
    "cli",
    "bridge",
    "codex",
    "claude",
    "opencode",
    "gemini",
    "copilot",
    "terminal"
  ],
  "author": "UNLINEARITY",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/UNLINEARITY/CLI-WeChat-Bridge.git"
  },
  "bugs": {
    "url": "https://github.com/UNLINEARITY/CLI-WeChat-Bridge/issues"
  },
  "homepage": "https://github.com/UNLINEARITY/CLI-WeChat-Bridge#readme",
  "bin": {
    "wechat-bridge": "./bin/wechat-bridge.mjs",
    "wechat-bridge-codex": "./bin/wechat-bridge-codex.mjs",
    "wechat-codex": "./bin/wechat-codex.mjs",
    "wechat-codex-start": "./bin/wechat-codex-start.mjs",
    "wechat-claude": "./bin/wechat-claude.mjs",
    "wechat-claude-start": "./bin/wechat-claude-start.mjs",
    "wechat-bridge-claude": "./bin/wechat-bridge-claude.mjs",
    "wechat-bridge-shell": "./bin/wechat-bridge-shell.mjs",
    "wechat-bridge-opencode": "./bin/wechat-bridge-opencode.mjs",
    "wechat-bridge-gemini": "./bin/wechat-bridge-gemini.mjs",
    "wechat-bridge-copilot": "./bin/wechat-bridge-copilot.mjs",
    "wechat-opencode": "./bin/wechat-opencode.mjs",
    "wechat-opencode-start": "./bin/wechat-opencode-start.mjs",
    "wechat-gemini": "./bin/wechat-gemini.mjs",
    "wechat-gemini-start": "./bin/wechat-gemini-start.mjs",
    "wechat-copilot": "./bin/wechat-copilot.mjs",
    "wechat-copilot-start": "./bin/wechat-copilot-start.mjs",
    "wechat-check-update": "./bin/wechat-check-update.mjs"
  },
  "scripts": {
    "setup": "node --no-warnings --experimental-strip-types src/wechat/setup.ts",
    "start": "node --no-warnings --experimental-strip-types src/wechat/wechat-channel.ts",
    "check": "node --no-warnings --experimental-strip-types src/wechat/wechat-channel.ts --check",
    "bridge": "node --no-warnings --experimental-strip-types src/bridge/wechat-bridge.ts",
    "bridge:codex": "node --no-warnings --experimental-strip-types src/bridge/wechat-bridge.ts --adapter codex",
    "codex:panel": "node --no-warnings --experimental-strip-types src/companion/local-companion.ts --adapter codex",
    "codex:start": "node --no-warnings --experimental-strip-types src/companion/local-companion-start.ts",
    "claude:start": "node --no-warnings --experimental-strip-types src/companion/local-companion-start.ts --adapter claude",
    "claude:companion": "node --no-warnings --experimental-strip-types src/companion/local-companion.ts --adapter claude",
    "bridge:claude": "node --no-warnings --experimental-strip-types src/bridge/wechat-bridge.ts --adapter claude",
    "bridge:shell": "node --no-warnings --experimental-strip-types src/bridge/wechat-bridge.ts --adapter shell",
    "bridge:opencode": "node --no-warnings --experimental-strip-types src/bridge/wechat-bridge.ts --adapter opencode",
    "bridge:gemini": "node --no-warnings --experimental-strip-types src/bridge/wechat-bridge.ts --adapter gemini",
    "bridge:copilot": "node --no-warnings --experimental-strip-types src/bridge/wechat-bridge.ts --adapter copilot",
    "opencode:panel": "node --no-warnings --experimental-strip-types src/companion/local-companion.ts --adapter opencode",
    "opencode:start": "node --no-warnings --experimental-strip-types src/companion/local-companion-start.ts --adapter opencode",
    "gemini:companion": "node --no-warnings --experimental-strip-types src/companion/local-companion.ts --adapter gemini",
    "gemini:start": "node --no-warnings --experimental-strip-types src/companion/local-companion-start.ts --adapter gemini",
    "copilot:companion": "node --no-warnings --experimental-strip-types src/companion/local-companion.ts --adapter copilot",
    "copilot:start": "node --no-warnings --experimental-strip-types src/companion/local-companion-start.ts --adapter copilot",
    "bridge:bun": "bun src/bridge/wechat-bridge.ts",
    "test": "bun test test",
    "test:bridge": "bun test test/bridge",
    "test:companion": "bun test test/companion",
    "test:wechat": "bun test test/wechat",
    "test:watch": "bun test --watch test"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.19.1",
    "@anthropic-ai/sdk": "^0.80.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@opencode-ai/sdk": "^1.3.2",
    "ajv-formats": "^3.0.1",
    "dotenv": "^17.4.2",
    "node-pty": "^1.1.0",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^6.0.2"
  },
  "engines": {
    "bun": ">=1.0.0",
    "node": ">=24.0.0"
  }
}
