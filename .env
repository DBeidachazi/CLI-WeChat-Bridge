# Bridge defaults
WECHAT_BRIDGE_DEFAULT_CLI_PROGRAM=codex
WECHAT_BRIDGE_DEFAULT_MODEL=gpt-5.4-mini
#WECHAT_BRIDGE_DEFAULT_CLI_PROGRAM=gemini
#WECHAT_BRIDGE_DEFAULT_MODEL=auto-gemini-3
WECHAT_BRIDGE_UPDATE_CHECK_HOUR=5
WECHAT_BRIDGE_TMUX_SESSION_PREFIX=wechat-bridge

# Codex defaults
WECHAT_BRIDGE_CODEX_MODEL=gpt-5.4-mini
WECHAT_BRIDGE_CODEX_APPROVAL_POLICY=never
WECHAT_BRIDGE_CODEX_SANDBOX=danger-full-access
WECHAT_BRIDGE_SPAWN_CODEX=codex --model gpt-5.4-mini --dangerously-bypass-approvals-and-sandbox

# Gemini ACP defaults
WECHAT_BRIDGE_GEMINI_MODEL=auto-gemini-3
WECHAT_BRIDGE_GEMINI_MODE=yolo
WECHAT_BRIDGE_SPAWN_GEMINI=gemini --acp

# Copilot ACP defaults
WECHAT_BRIDGE_COPILOT_MODEL=gpt-5.4-mini
WECHAT_BRIDGE_COPILOT_MODE=https://agentclientprotocol.com/protocol/session-modes#autopilot
WECHAT_BRIDGE_SPAWN_COPILOT=copilot --acp --stdio

# Other adapters
WECHAT_BRIDGE_SPAWN_CLAUDE=claude
WECHAT_BRIDGE_SPAWN_OPENCODE=opencode
WECHAT_BRIDGE_SPAWN_SHELL=bash

# ACP permission handling
WECHAT_BRIDGE_ACP_AUTO_APPROVE=true
WECHAT_BRIDGE_LOG_TRANSCRIPT=true
WECHAT_BRIDGE_BACKGROUND_LOG_TO_CONTAINER=true

# Container/runtime bootstrap
WECHAT_BRIDGE_AUTO_INSTALL_CLIS=true
WECHAT_BRIDGE_AUTO_WECHAT_SETUP=true
WECHAT_BRIDGE_INSTALL_CODEX=npm install -g @openai/codex
WECHAT_BRIDGE_INSTALL_GEMINI=npm install -g @google/gemini-cli
WECHAT_BRIDGE_INSTALL_COPILOT=npm install -g @github/copilot
WECHAT_BRIDGE_INSTALL_CLAUDE=npm install -g @anthropic-ai/claude-code
WECHAT_BRIDGE_INSTALL_OPENCODE=npm install -g opencode-ai
